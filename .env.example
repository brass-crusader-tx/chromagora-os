# Chromagora OS — Environment Variables
# Copy to .env and fill in your Supabase project credentials

# Supabase (required for database, auth, realtime, storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (direct connection for migrations)
DATABASE_URL=postgresql://postgres:postgres@db.your-project.supabase.co:5432/postgres

# Frontend (Next.js — NEXT_PUBLIC_ prefix makes them available in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API
API_HOST=127.0.0.1
API_PORT=8000
CHROMAGORA_ENV=development

# OpenRouter (free model routing)
OPENROUTER_API_KEY=sk-or-v1-...

# Feature flags
ENABLE_VECTOR_MEMORY=false
ENABLE_REAL_EMAIL_SENDING=false

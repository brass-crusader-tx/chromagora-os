# Chromagora OS — Environment Variables
# Copy to .env and fill in your Supabase project credentials

# Supabase (required for database, auth, realtime, storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy names still work if your Supabase project has not migrated keys yet.
SUPABASE_ANON_KEY=your-legacy-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (direct connection for migrations)
DATABASE_URL=postgresql://postgres:postgres@db.your-project.supabase.co:5432/postgres

# Frontend (Next.js — NEXT_PUBLIC_ prefix makes them available in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API
API_HOST=127.0.0.1
API_PORT=8000
CHROMAGORA_ENV=development
# Comma-separated operator/demo API keys. Required when ENFORCE_AUTH=true.
API_KEYS=local-dev-key-change-me
ENFORCE_AUTH=false

# Model providers
NVIDIA_API_KEY=nvapi-...
OPENROUTER_API_KEY=

# Demo Factory model/crawl/render runtime
DEMO_FACTORY_PRIMARY_MODEL=stepfun-ai/step-3.7-flash
DEMO_FACTORY_FALLBACK_MODEL=
DEMO_FACTORY_MODEL_MAX_ATTEMPTS=2
DEMO_FACTORY_MAX_RPM=18
DEMO_FACTORY_MAX_DAILY_REQUESTS=500
DEMO_FACTORY_RATE_LIMIT_COOLDOWN_SECONDS=120
# Set to mock only for offline tests/dev. Supported live providers: nvidia, openrouter.
DEMO_FACTORY_MODEL_PROVIDER=nvidia
DEMO_FACTORY_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
DEMO_FACTORY_NVIDIA_TOP_P=0.95
DEMO_FACTORY_CRAWLER_PROVIDER=
DEMO_FACTORY_BRIGHTDATA_API_KEY=
DEMO_FACTORY_BRIGHTDATA_ZONE=
DEMO_FACTORY_BRIGHTDATA_TIMEOUT_SECONDS=90
DEMO_FACTORY_CRAWL_MAX_PAGES=5
DEMO_FACTORY_CRAWL_HTTP_TIMEOUT_SECONDS=20
DEMO_FACTORY_GOOGLE_MAPS_REVIEWS_ENABLED=true
DEMO_FACTORY_GOOGLE_MAPS_TIMEOUT_SECONDS=75
DEMO_FACTORY_REVIEW_SOURCE_LIMIT=5
# Required for screenshot Visual QA against the Next renderer.
DEMO_FACTORY_RENDER_BASE_URL=http://localhost:3000
DEMO_FACTORY_PUBLIC_BASE_URL=http://localhost:3000
DEMO_FACTORY_VISUAL_QA_REQUIRED=false

# Workers
WORKER_ID=local-worker-1
WORKER_INTERVAL_SECONDS=300

# Feature flags
ENABLE_VECTOR_MEMORY=false
ENABLE_REAL_EMAIL_SENDING=false

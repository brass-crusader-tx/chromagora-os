# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: only for local/operator demos when backend X-API-Key auth is enabled.
# Do not use a service-role secret here; this value is visible in the browser.
NEXT_PUBLIC_CHROMAGORA_API_KEY=local-dev-key-change-me
